# ============================================================================
# Vyara — Environment configuration template
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Production values live in the deployment platform's secrets store, not here.
# ============================================================================

# --- Database (BE-01) -------------------------------------------------------
# Local dev (after `docker compose up -d postgres`):
DATABASE_URL="postgresql://vyara:vyara_dev_password@localhost:5432/vyara?schema=public"

# Postgres container settings (only used by docker-compose.yml)
POSTGRES_DB=vyara
POSTGRES_USER=vyara
POSTGRES_PASSWORD=vyara_dev_password
POSTGRES_PORT=5432
ADMINER_PORT=8080
