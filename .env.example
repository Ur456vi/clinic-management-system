# ============================================================================
# Vyara — Environment configuration template
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Production values live in the deployment platform's secrets store.
#
# Conventions:
#   - Public vars exposed to the browser are prefixed with `NEXT_PUBLIC_`.
#   - Anything secret must NEVER be prefixed with NEXT_PUBLIC_.
#   - Comments above each var explain what it does and the task that needs it.
# ============================================================================

# --- Application ------------------------------------------------------------
# Public URL of the app (no trailing slash). Used in emails, payment callbacks.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Internal URL used for server-to-server requests inside the deployment.
# Usually identical to NEXT_PUBLIC_APP_URL in single-region setups.
APP_URL="http://localhost:3000"

# "development" | "test" | "production"  (Next.js sets this for you in most flows)
NODE_ENV="development"

# --- Database (BE-01 / BE-02) -----------------------------------------------
# After `docker compose up -d postgres`:
DATABASE_URL="postgresql://postgres:admin@localhost:5432/Vyara?schema=public"

# Postgres container settings (only used by docker-compose.yml)
POSTGRES_DB=Vyara
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_PORT=5432
ADMINER_PORT=8080

# --- Auth (BE-04, BE-05) ----------------------------------------------------
# NextAuth.js — secret used to sign session JWTs. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Password OTP — TTL (seconds) and length. Defaults below are sensible.
OTP_TTL_SECONDS=300
OTP_LENGTH=5

# --- Email (BE-34) ----------------------------------------------------------
# Resend (recommended). Sign up at https://resend.com, create an API key.
RESEND_API_KEY=""
# Brevo (alternative). Sign up at https://brevo.com, create an API key.
BREVO_API_KEY=""
EMAIL_FROM="Vyara <no-reply@vyara.local>"

# --- WhatsApp (BE-33) -------------------------------------------------------
# Meta Cloud API. Get these from developers.facebook.com.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_VERIFY_TOKEN=""

# --- File storage (BE-19) ---------------------------------------------------
# S3-compatible bucket for lab PDFs, photos, ID docs.
# Cloudflare R2 example (S3 API):
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="vyara-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# --- Payments (BE-41) -------------------------------------------------------
# Razorpay credentials. Dashboard → Settings → API Keys.
#
# Sprint 1 ships a MOCK Razorpay integration — `lib/services/razorpay.ts`
# falls back to the literal defaults below when these vars are empty, so
# `npm run dev` works without a Razorpay account. Real test/live keys
# land in Sprint 2 once the official `razorpay` Node SDK is wired in.
RAZORPAY_KEY_ID="rzp_test_mock_key"
RAZORPAY_KEY_SECRET="mock-secret"
RAZORPAY_WEBHOOK_SECRET="mock-webhook-secret"

# --- Encryption at rest (BE-53) ---------------------------------------------
# Used to encrypt PHI columns. 32 bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
DATA_ENCRYPTION_KEY=""

# --- Observability (BE-10) --------------------------------------------------
# Log level: "trace" | "debug" | "info" | "warn" | "error"
LOG_LEVEL="info"

# Sentry (optional, recommended for production)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# --- Feature flags (optional) -----------------------------------------------
# Toggle features without a redeploy. Keep this list short.
FEATURE_PATIENT_PORTAL="false"

# --- Security (BE-52) -------------------------------------------------------
# Comma-separated list of origins permitted to make CORS requests with
# credentials. If unset, only http://localhost:3000 is allowed.
CORS_ALLOWED_ORIGINS=http://localhost:3000
