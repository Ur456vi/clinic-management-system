// Vyara — Prisma schema
//
// Initial scaffold. Models are introduced incrementally:
//   BE-03  : User, Role, Patient, Staff, Department, AuditLog (this commit)
//   BE-13  : Consultation (RMO + Main, sectioned JSONB)
//   BE-16  : LabResult (per-panel rows with analytes JSONB)
//   BE-24  : TreatmentPlan + plan items
//   BE-27  : Appointment
//   BE-37  : Invoice / InvoiceItem / Payment
//
// Run `npm run prisma:format` after edits to keep style consistent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Enums
// ===========================================================================

/// Clinic-side roles. A staff member always has exactly one role; a patient
/// has no Role (they sign in via a separate patient portal in BE-47).
enum Role {
  ADMIN
  DOCTOR
  RMO
  RECEPTION
  INFUSION_SPECIALIST
  REHAB_SPECIALIST
  AESTHETICS_SPECIALIST
  PATIENT
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNDISCLOSED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
}

enum ConsultationType {
  RMO
  MAIN
}

enum ConsultationStatus {
  DRAFT
  RMO_DONE
  IN_PROGRESS
  SIGNED
}

/// Per-analyte out-of-range flag for a `LabResult` analyte (BE-16).
///
/// `LOW` / `HIGH` cover the standard reference-range comparison; the
/// `CRITICAL_*` variants reserve the future ability for the lab to mark a
/// value as life-threatening (panic value). `NORMAL` is set by the
/// flag-computation helper when a numeric value sits inside `[refLow,
/// refHigh]`. `ABNORMAL` is used for non-numeric analytes (e.g. urine
/// culture "POSITIVE") that cannot be range-compared.
enum LabFlag {
  LOW
  HIGH
  CRITICAL_LOW
  CRITICAL_HIGH
  NORMAL
  ABNORMAL
}

/// Appointment lifecycle (BE-27).
///
///   REQUESTED  -> CONFIRMED | CANCELLED
///   CONFIRMED  -> COMPLETED | CANCELLED | NO_SHOW
///   COMPLETED / CANCELLED / NO_SHOW are terminal.
///
/// Only REQUESTED + CONFIRMED rows participate in slot-conflict checks —
/// once a slot is COMPLETED / CANCELLED / NO_SHOW it no longer holds the
/// staff member's time. Transitions are enforced in the service layer
/// (`lib/services/appointment.ts`).
enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

/// Treatment plan lifecycle (BE-24).
///
///   DRAFT   -> SIGNED   (doctor signs the plan; immutable thereafter)
///   SIGNED  -> REVOKED  (clinician revokes a signed plan)
///   DRAFT   -> REVOKED  (drafts can be discarded as well)
///
/// Service layer enforces transitions; SIGNED is otherwise terminal for
/// content edits — only the sign endpoint stamps `signedAt`/`signedById`.
enum TreatmentPlanStatus {
  DRAFT
  SIGNED
  REVOKED
}

/// Plan-item discriminator. The line items in a TreatmentPlan are a flat
/// list across these five clinical buckets — keeps the FE list rendering
/// trivial. Per-kind structured fields will land in BE-26 (protocol
/// library).
enum PlanItemKind {
  RX
  SUPPLEMENT
  IV
  REHAB
  AESTHETIC
}

/// Infusion log lifecycle (BE-26).
///
///   SCHEDULED   -> IN_PROGRESS | ABORTED
///   IN_PROGRESS -> COMPLETED   | ABORTED
///   COMPLETED / ABORTED are terminal.
///
/// Transitions are enforced in the service layer
/// (`lib/services/infusion-log.ts`); the route layer is a thin wrapper
/// that calls `transitionInfusionLog`.
enum InfusionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ABORTED
}

// ===========================================================================
// Auth & org
// ===========================================================================

/// A login account. Always 1:1 with Staff for clinic users.
/// Patient portal logins (BE-47) will use a separate model.
model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.Citext
  passwordHash String    @map("password_hash")
  role         Role
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  /// Set when the account is created with a system-generated temporary
  /// password (e.g. self-enrol via the public assessment flow). While
  /// true, the proxy forces the user to /reset-password before they can
  /// use the portal; cleared on the first successful password change.
  mustResetPassword Boolean @default(false) @map("must_reset_password")

  /// Per-user notification toggles (which email alerts to send). JSONB map
  /// of `channel -> boolean`, e.g. `{ "appointments": true, "labResults":
  /// false, "prescriptions": true }`. Null = all-on defaults (see
  /// `lib/validation/notification-preferences.ts`).
  notificationPrefs Json? @map("notification_prefs") @db.JsonB

  staff   Staff?
  /// 1:1 back-relation for unified-portal logins where role=PATIENT.
  patient Patient?

  consultationsCreated Consultation[] @relation("ConsultationCreator")
  consultationsSigned  Consultation[] @relation("ConsultationSigner")

  treatmentPlansCreated TreatmentPlan[] @relation("PlanCreator")
  treatmentPlansSigned  TreatmentPlan[] @relation("PlanSigner")
  treatmentPlansRevoked TreatmentPlan[] @relation("PlanRevoker")

  passwordResetOtps PasswordResetOtp[]

  /// In-app notification feed (BE-45). One row per delivered event.
  notifications Notification[]

  /// Vitals readings this user (staff/RMO) recorded for patients.
  vitalsRecorded Vital[] @relation("VitalRecorder")

  @@index([role])
  @@map("users")
}

model Department {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  slug           String   @unique
  description    String?
  isActive       Boolean  @default(true) @map("is_active")
  /// Default service pricing for this department (BE-31).
  ///
  /// JSONB map of `serviceCode -> priceCents` (integer paise/cents).
  /// Example: `{ "consultation": 50000, "follow_up": 30000 }`.
  /// Read by the appointment + invoice surfaces to seed line-item amounts
  /// when a more specific override isn't set. The shape is intentionally
  /// open-ended for Sprint 1 — BE-37 will introduce a normalised
  /// `ServicePrice` table and migrate values out of this column.
  defaultPricing Json?    @map("default_pricing")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  staff        Staff[]
  appointments Appointment[]
  invoices     Invoice[]

  @@map("departments")
}

model Staff {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @unique @map("user_id") @db.Uuid
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  fullName       String    @map("full_name")
  phone          String?
  dateOfBirth    DateTime? @map("date_of_birth") @db.Date
  specialization String?
  licenseNumber  String?   @map("license_number")
  experienceYrs  Int?      @map("experience_yrs")
  qualifications String[]  @default([])
  biography      String?
  avatarUrl      String?   @map("avatar_url")
  address        String?
  isActive       Boolean   @default(true) @map("is_active")
  joinedAt       DateTime? @map("joined_at") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Patients this staff member is the primary doctor for.
  primaryPatients Patient[] @relation("PrimaryDoctor")

  // Lab results this staff member ordered (BE-16).
  labResultsOrdered LabResult[] @relation("LabResultOrderingDoctor")

  // Appointments where this staff member is the assigned doctor/RMO (BE-27).
  appointments        Appointment[] @relation("AppointmentStaff")
  // Appointments this staff member created (typically RECEPTION).
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")

  // Infusion logs administered by this staff member (BE-26).
  infusionLogs InfusionLog[] @relation("InfusionStaff")

  @@index([departmentId])
  @@map("staff")
}

// ===========================================================================
// Patients
// ===========================================================================

model Patient {
  id            String @id @default(uuid()) @db.Uuid
  /// Human-readable patient number, e.g. "PAT-263040".
  /// Generated via a sequence in BE-09 seed/migration.
  patientNumber String @unique @map("patient_number")

  fullName         String    @map("full_name")
  email            String?   @db.Citext
  phone            String?
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  sex              Sex?
  occupation       String?
  placeOfResidence String?   @map("place_of_residence")
  address          String?
  /// S3 object key (assets bucket) for the patient's profile photo.
  /// Same shape as Staff.avatarUrl — null when no avatar is uploaded.
  avatarUrl        String?   @map("avatar_url")

  status PatientStatus @default(ACTIVE)

  /// Optional 1:1 back-relation to a unified-portal login. Populated for
  /// patients who have signed up for the patient portal (BE-47 + unified
  /// portal consolidation). Nullable because clinic-created patients won't
  /// have a User row until they self-enroll.
  userId String? @unique @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Optional primary doctor (Staff with role DOCTOR).
  primaryDoctorId String? @map("primary_doctor_id") @db.Uuid
  primaryDoctor   Staff?  @relation("PrimaryDoctor", fields: [primaryDoctorId], references: [id], onDelete: SetNull)

  referralSource String? @map("referral_source")

  /// Soft delete — set when status becomes ARCHIVED. Keep the row for audit.
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consultations  Consultation[]
  appointments   Appointment[]
  labResults     LabResult[]
  treatmentPlans TreatmentPlan[]
  invoices       Invoice[]
  infusionLogs   InfusionLog[]
  vitals         Vital[]
  /// Every completed public-site Health Assessment quiz is captured here.
  /// One row per attempt — retakes are stored as fresh rows so the doctor
  /// can compare scores over time.
  assessmentSubmissions AssessmentSubmission[]

  @@index([status])
  @@index([primaryDoctorId])
  @@index([fullName])
  @@map("patients")
}

// ===========================================================================
// Vitals
// ===========================================================================
//
// A point-in-time vitals reading for a patient, recorded by staff/RMO
// (e.g. during a consultation) or surfaced on the patient dashboard. All
// measurement fields are nullable so a partial reading (just BP, say) is
// valid. The latest row by `recordedAt` is what the dashboard shows.
model Vital {
  id        String  @id @default(uuid()) @db.Uuid
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  /// Staff/RMO who recorded the reading. Null if recorded by an automated
  /// import or if the recorder's account was later removed.
  recordedById String? @map("recorded_by_id") @db.Uuid
  recordedBy   User?   @relation("VitalRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  systolic     Int? // mmHg
  diastolic    Int? // mmHg
  heartRate    Int?   @map("heart_rate") // bpm
  weightKg     Float? @map("weight_kg")
  heightCm     Float? @map("height_cm")
  temperatureF Float? @map("temperature_f")
  spo2         Int? // %
  notes        String?

  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz()
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([patientId, recordedAt(sort: Desc)])
  @@map("vitals")
}

// ===========================================================================
// Consultations (BE-13)
// ===========================================================================

/// A clinical encounter. Polymorphic single-table design — `type` discriminates
/// between an RMO intake pass and the senior doctor's main consultation, and
/// the per-section payload lives in the `sections` JSONB blob. We deliberately
/// chose JSONB over normalized per-section tables because the intake form has
/// ~150 fields across 30+ sub-sections; per-section tables would explode the
/// migration surface area with no query benefit at clinic scale.
model Consultation {
  id        String  @id @default(uuid()) @db.Uuid
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  type   ConsultationType
  status ConsultationStatus @default(DRAFT)

  /// The RMO or Doctor who started this consultation.
  createdById String? @map("created_by_id") @db.Uuid
  createdBy   User?   @relation("ConsultationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  /// Set when the consultation transitions to SIGNED. After signing the row
  /// is immutable (enforced in BE-14's service layer).
  signedById String?   @map("signed_by_id") @db.Uuid
  signedBy   User?     @relation("ConsultationSigner", fields: [signedById], references: [id], onDelete: SetNull)
  signedAt   DateTime? @map("signed_at")

  /// Free-form sectioned content. For RMO: keys "informant", "demographics",
  /// "medicalHistory", "socialHistory", "personalHistory", "examinationSummary".
  /// For MAIN: "chiefComplaint", "hpi", "assessment", "diagnosis", "plan".
  sections Json @default("{}")

  /// Optional summary surfaced in the patient timeline.
  summary String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  labResults LabResult[]
  infusions  InfusionLog[]

  /// Back-relation for the appointment this consultation was started from
  /// (see Appointment.consultationId). Optional — a consultation can also
  /// be created standalone from the patient chart.
  appointment Appointment? @relation("AppointmentConsultation")

  @@index([patientId, type, createdAt])
  @@index([status])
  @@index([createdById])
  @@map("consultations")
}

// ===========================================================================
// Audit log
// ===========================================================================

/// Append-only audit trail. Every read/write of PHI writes a row here.
/// Surfaced through an admin viewer endpoint in BE-23.
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  occurredAt DateTime @default(now()) @map("occurred_at")

  /// Who did it (null for system events).
  actorUserId String? @map("actor_user_id") @db.Uuid

  action     AuditAction
  /// Entity table/model name, e.g. "Patient", "Consultation".
  entityType String      @map("entity_type")
  /// Primary key of the affected row (string so it fits uuid + bigint).
  entityId   String?     @map("entity_id")

  /// Optional structured detail (request ip, before/after diff, etc.).
  detail Json?

  @@index([entityType, entityId])
  @@index([actorUserId, occurredAt])
  @@index([occurredAt])
  @@map("audit_logs")
}

// ===========================================================================
// Appointments (BE-27)
// ===========================================================================

/// A scheduled clinical encounter between a Patient and a Staff member
/// (typically a doctor or RMO). The lifecycle is `AppointmentStatus` —
/// transitions are gated in `lib/services/appointment.ts`.
///
/// Slot-conflict semantics:
/// On create / time-edit, the service rejects any overlap on `staffId`
/// with another appointment whose status is in `{REQUESTED, CONFIRMED}`.
/// COMPLETED / CANCELLED / NO_SHOW rows no longer hold the slot.
///
/// onDelete policy:
///   - Patient & Staff: `Restrict` — never silently lose a scheduled
///     appointment when a person is removed.
///   - Department: `SetNull` — departments can be retired without
///     dropping historical bookings.
model Appointment {
  id String @id @default(uuid()) @db.Uuid

  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  /// Assigned doctor / RMO for this appointment.
  staffId String @map("staff_id") @db.Uuid
  staff   Staff  @relation("AppointmentStaff", fields: [staffId], references: [id], onDelete: Restrict)

  /// Optional department snapshot — useful for room/queue routing in
  /// later sprints. SetNull keeps history intact if the department is
  /// retired.
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  startsAt DateTime @map("starts_at") @db.Timestamptz()
  endsAt   DateTime @map("ends_at") @db.Timestamptz()

  status AppointmentStatus @default(REQUESTED)

  /// Short free-text reason for the visit (chief complaint shorthand).
  reason String?
  /// Optional reception/clinical notes attached to the booking itself
  /// (not the consultation — that's a separate row).
  notes  String?

  /// Who booked the appointment. Optional — system-created bookings
  /// (e.g. follow-up suggestions in BE-28) may have no creator.
  createdById String? @map("created_by_id") @db.Uuid
  createdBy   Staff?  @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  /// Stamped when the row transitions to CANCELLED. Kept for audit /
  /// patient-timeline display alongside `cancelledReason`.
  cancelledAt     DateTime? @map("cancelled_at") @db.Timestamptz()
  cancelledReason String?   @map("cancelled_reason")

  /// The clinical consultation started from this appointment via the admin
  /// "Start appointment" action. 1:1 — re-starting reuses the same row so
  /// a chart is never duplicated. SetNull keeps the booking if the
  /// consultation is later removed.
  consultationId String?       @unique @map("consultation_id") @db.Uuid
  consultation   Consultation? @relation("AppointmentConsultation", fields: [consultationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoices Invoice[]

  // Slot-conflict checks scan by (staffId, startsAt).
  @@index([staffId, startsAt])
  // Patient timeline view orders most-recent first.
  @@index([patientId, startsAt(sort: Desc)])
  @@map("appointments")
}

// ===========================================================================
// Treatment plans (BE-24)
// ===========================================================================

/// A clinical treatment plan attached to a Patient. Composed of a header
/// (title, summary, status, signature stamp) and an ordered list of
/// `TreatmentPlanItem` rows that span five clinical kinds — Rx,
/// supplement, IV, rehab, aesthetic.
///
/// Lifecycle: DRAFT -> SIGNED -> REVOKED (see `TreatmentPlanStatus`).
/// Once SIGNED the plan is immutable from the PATCH endpoint; only
/// `/sign` and a future `/revoke` (BE-25) may alter the row. The plan
/// is created at version 1 — versioning beyond v1 (immutable history of
/// edits) is deferred to BE-25.
///
/// onDelete policy:
///   - Patient: `Cascade` — wiping a patient wipes their plans (PHI).
///   - createdBy / signedBy User: `SetNull` — keep the plan intact even
///     when an authoring account is removed.
model TreatmentPlan {
  id        String  @id @default(uuid()) @db.Uuid
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  /// Doctor (or admin acting on their behalf) who drafted this plan.
  createdById String? @map("created_by_id") @db.Uuid
  createdBy   User?   @relation("PlanCreator", fields: [createdById], references: [id], onDelete: SetNull)

  status TreatmentPlanStatus @default(DRAFT)

  title   String
  summary String?

  /// Stamped when the plan transitions to SIGNED. After signing the row
  /// is immutable from the PATCH endpoint (enforced in the service).
  signedAt   DateTime? @map("signed_at")
  signedById String?   @map("signed_by_id") @db.Uuid
  signedBy   User?     @relation("PlanSigner", fields: [signedById], references: [id], onDelete: SetNull)

  /// Plan version number. v1 for first issuance; cloning via the
  /// `/version` endpoint (BE-25) increments from the source row.
  version Int @default(1)

  /// Back-pointer to the plan this row was cloned from (BE-25). NULL on
  /// the root version. SetNull on delete so a pruned ancestor does not
  /// orphan its descendants.
  previousVersionId String?         @map("previous_version_id") @db.Uuid
  previousVersion   TreatmentPlan?  @relation("PlanVersionChain", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions      TreatmentPlan[] @relation("PlanVersionChain")

  /// Revoke metadata (BE-25). Stamped when the plan transitions to
  /// REVOKED — `revokedById` is the actor (admin or signing doctor),
  /// `revokeReason` is the optional free-text note from the request.
  revokedAt    DateTime? @map("revoked_at")
  revokedById  String?   @map("revoked_by_id") @db.Uuid
  revokedBy    User?     @relation("PlanRevoker", fields: [revokedById], references: [id], onDelete: SetNull)
  revokeReason String?   @map("revoke_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items TreatmentPlanItem[]

  @@index([patientId, status])
  @@index([patientId, createdAt])
  @@index([previousVersionId])
  @@map("treatment_plans")
}

/// One line item on a TreatmentPlan. Cascade-deleted with its parent
/// (line items have no meaning standalone).
///
/// `kind` discriminates the clinical bucket; the structured fields
/// (`dose`, `frequency`, `durationDays`, `instructions`) are deliberately
/// loose strings/ints in Sprint 1 — the protocol library (BE-26) will
/// constrain them per-kind.
model TreatmentPlanItem {
  id     String        @id @default(uuid()) @db.Uuid
  planId String        @map("plan_id") @db.Uuid
  plan   TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  kind PlanItemKind

  name         String
  dose         String?
  frequency    String?
  durationDays Int?    @map("duration_days")
  instructions String?

  /// Display order within the plan. Defaults to 0 — service callers
  /// should pass a monotonic sequence when ordering matters.
  sequence Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([planId, sequence])
  @@map("treatment_plan_items")
}

// ===========================================================================
// NextAuth (BE-04)
// ===========================================================================
//
// We use the JWT session strategy, so these models are not exercised at
// runtime. They are declared because the PrismaAdapter contract expects
// them to exist when present, and we want zero-friction migration to the
// database-session strategy later.
//
// The `passwordHash` column on User already exists from BE-03 and is the
// canonical credential store; the `Account` model (used by OAuth providers)
// is intentionally omitted until we add a non-credentials provider.

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================================================================
// Password reset (BE-05)
// ===========================================================================

/// One row per OTP request. The plaintext OTP is never stored — only its
/// bcrypt hash. The row is burned (usedAt set) on successful verification.
///
/// Rate-limit policy lives in the route layer: max 5 requests per email per
/// rolling hour, counted via `createdAt`. A Sprint-2 hardening item is to
/// move this to Redis or a token bucket (`docs/auth.md`).
model PasswordResetOtp {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// bcrypt hash of the 6-digit code.
  otpHash String @map("otp_hash")

  /// Absolute expiry — set to createdAt + ~15 min at issue time.
  expiresAt DateTime @map("expires_at")

  /// Set on successful verification. Once non-null the row is consumed and
  /// cannot satisfy another verify call.
  usedAt DateTime? @map("used_at")

  /// Number of verify attempts against this OTP. Caller bumps on each
  /// mismatch and stops accepting the row at 5 attempts.
  attempts Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("password_reset_otps")
}

// ===========================================================================
// Lab results (BE-16)
// ===========================================================================

/// A single lab panel result. One row per panel (CBC, LFT, Vit D, etc.); the
/// per-analyte rows are stored as a JSON array in `analytes` rather than
/// normalised into a separate table — at clinic scale (~thousands of results
/// per year) the JSONB shape is simpler and matches how labs return data.
///
/// Each entry in `analytes` is shaped:
///
///   {
///     "name":     "Hemoglobin",
///     "value":    "13.4" | 13.4,        // string OR number; non-numeric labs are common
///     "unit":     "g/dL",                // optional
///     "refLow":   12.0,                  // optional, numeric
///     "refHigh":  16.0,                  // optional, numeric
///     "flag":     "LOW" | "HIGH" | "CRITICAL_LOW" | "CRITICAL_HIGH"
///                 | "NORMAL" | "ABNORMAL"   // optional; computed server-side
///                                            // when refLow/refHigh present
///                                            // and not explicitly set.
///   }
///
/// `attachmentKey` / `attachmentMime` are the S3 object key + content-type
/// for the original PDF/image. They are nullable here and populated by
/// BE-19's presigned-upload flow once that lands; until then the row exists
/// without an attachment and the analytes payload is the source of truth.
model LabResult {
  id             String        @id @default(uuid()) @db.Uuid
  patientId      String        @map("patient_id") @db.Uuid
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  /// Optional — a lab can predate the consultation it eventually feeds into.
  consultationId String?       @map("consultation_id") @db.Uuid
  consultation   Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)

  /// Human-readable panel label, e.g. "CBC", "LFT", "Vit D".
  panelName String @map("panel_name")

  /// When the sample was drawn / collected.
  collectedAt DateTime  @map("collected_at")
  /// When the lab issued the report — nullable while the result is pending.
  reportedAt  DateTime? @map("reported_at")

  /// Doctor who ordered the panel. Nullable for results uploaded outside a
  /// scheduled consultation (e.g. a patient brings in an old report).
  orderingDoctorId String? @map("ordering_doctor_id") @db.Uuid
  orderingDoctor   Staff?  @relation("LabResultOrderingDoctor", fields: [orderingDoctorId], references: [id], onDelete: SetNull)

  /// External lab / facility that produced the report ("Metropolis", "SRL",
  /// "in-house", ...). Free-form to keep BE-16 unblocked; BE-19+ may promote
  /// this to a Lab model.
  labName String? @map("lab_name")

  /// Per-analyte rows. See the doc-block above for the per-element shape.
  analytes Json @default("[]")

  /// Optional one-liner surfaced in the patient timeline.
  summary String?

  /// S3 object key for the attached PDF/image. Populated by BE-19 once the
  /// presigned-upload flow lands; nullable until then.
  attachmentKey  String?  @map("attachment_key")
  attachmentMime String?  @map("attachment_mime")
  attachmentUploadedAt DateTime? @map("attachment_uploaded_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([patientId, collectedAt])
  @@index([consultationId])
  @@map("lab_results")
}

// Billing — Invoice / InvoiceItem / Payment (BE-37)
// ===========================================================================
//
// Owns the revenue surface for the May 28 demo. Money is stored as integer
// *_Cents columns to dodge floating-point drift; `taxRateBps` is in basis
// points (1800 = 18.00%) for the same reason.
//
// Invoices are *not* deleted — `status = VOID` is the soft-delete. The
// reasonable concern is that this table holds PHI-adjacent + financial
// data; the PM owns a legal advisory memo filed at merge time (see
// `docs/legal/`).
//
// Line items reference their source entity polymorphically via
// `sourceType` + `sourceRefId` so this model stays independent of the
// in-flight TreatmentPlan / InfusionSession branches. The trade-off is
// no FK from `invoice_items.source_ref_id`; the service layer is
// responsible for validating the reference at insert time when needed.
//
// Razorpay webhook integration is BE-41 (sprint plan Day 11 PM); this
// task only adds the model + a `gatewayRef` slot to hang the payment id
// off of.

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
}

enum InvoiceItemSourceType {
  MANUAL
  CONSULTATION
  TREATMENT_PLAN
  INFUSION_SESSION
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

/// A patient invoice. Totals are cached on the row (subtotal/tax/total in
/// cents) and recomputed from `items` whenever the line set changes; the
/// service layer is the single writer.
///
/// `placeOfSupply` is the Indian-GST state code (e.g. "GJ" for Gujarat) —
/// it controls IGST vs CGST/SGST split downstream when we generate the
/// GST-compliant PDF (post-Sprint-1). `gstNumber` is the *clinic's*
/// GSTIN snapshot at invoice time so historical invoices stay correct if
/// the clinic ever re-registers.
model Invoice {
  id            String @id @default(uuid()) @db.Uuid
  /// Human-readable invoice number, e.g. "INV-2026-000123".
  /// Generated by the service layer; uniqueness is enforced here.
  invoiceNumber String @unique @map("invoice_number")

  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  /// Optional appointment linkage — invoices generated from a completed
  /// consultation point back at the originating booking.
  appointmentId String?      @map("appointment_id") @db.Uuid
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  /// Department the billed service belongs to. Chosen by reception at
  /// check-in; SetNull keeps the invoice if the department is retired.
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  /// Sum of `lineSubtotalCents` across items.
  subtotalCents Int @map("subtotal_cents")
  /// Sum of `lineTaxCents` across items.
  taxCents      Int @map("tax_cents")
  /// `subtotalCents + taxCents`.
  totalCents    Int @map("total_cents")

  /// Clinic GSTIN snapshot at issue time.
  gstNumber     String? @map("gst_number")
  /// Indian state code for GST place-of-supply (e.g. "GJ", "MH").
  placeOfSupply String? @map("place_of_supply")

  status InvoiceStatus @default(DRAFT)

  notes String?

  /// Set when the invoice leaves DRAFT (transition to ISSUED).
  issuedAt  DateTime? @map("issued_at")
  /// Optional due date for ISSUED / PARTIALLY_PAID invoices.
  dueAt     DateTime? @map("due_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  items    InvoiceItem[]
  payments Payment[]

  @@index([patientId, createdAt(sort: Desc)])
  @@index([status])
  @@index([appointmentId])
  @@index([departmentId])
  @@map("invoices")
}

/// A single line on an `Invoice`.
///
/// `quantity` is `Decimal(10,3)` to allow fractional units (e.g. 1.5
/// hours of infusion time). `taxRateBps` is in basis points so an 18%
/// GST rate is `1800`; `lineTaxCents = round(lineSubtotalCents *
/// taxRateBps / 10000)`. All line-level totals are persisted so we
/// don't have to recompute on every read.
///
/// `sourceType` + `sourceRefId` is a polymorphic reference back to the
/// underlying clinical entity. No FK is enforced — the service layer
/// resolves the reference when the line is created.
model InvoiceItem {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description    String
  /// HSN/SAC code for Indian GST classification (numeric string).
  hsnSac         String? @map("hsn_sac")
  quantity       Decimal @default(1) @db.Decimal(10, 3)
  unitPriceCents Int     @map("unit_price_cents")
  /// Tax rate in basis points (1800 == 18.00%).
  taxRateBps     Int     @map("tax_rate_bps")

  lineSubtotalCents Int @map("line_subtotal_cents")
  lineTaxCents      Int @map("line_tax_cents")
  lineTotalCents    Int @map("line_total_cents")

  sourceType  InvoiceItemSourceType @default(MANUAL) @map("source_type")
  /// Polymorphic reference to the source entity (no FK; service-layer
  /// validated). Null for MANUAL lines.
  sourceRefId String?               @map("source_ref_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([invoiceId])
  @@index([sourceType, sourceRefId])
  @@map("invoice_items")
}

/// A payment attempt against an `Invoice`. One invoice can have many
/// payments (partial payments, refunds). The invoice's `status` is
/// recomputed by the service layer after each captured/refunded payment.
///
/// `gatewayRef` is the upstream gateway's payment id — populated by the
/// Razorpay webhook in BE-41. Cash / card / UPI payments recorded at the
/// reception desk leave it null.
model Payment {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amountCents Int           @map("amount_cents")
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)

  /// Upstream gateway payment id (Razorpay). Null for manual methods.
  gatewayRef String? @map("gateway_ref")

  receivedAt DateTime @default(now()) @map("received_at")
  notes      String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([invoiceId, receivedAt(sort: Desc)])
  @@index([status])
  @@index([gatewayRef])
  @@map("payments")
}

// ===========================================================================
// Infusion logs (BE-26)
// ===========================================================================

/// A single integrative-medicine IV / infusion encounter. Recorded by the
/// infusion-specialist or supervising clinician for protocol traceability:
/// what was administered, by whom, when started/completed, and whether the
/// patient had a reaction. The `agents` JSONB array carries the per-agent
/// order (name + dose + unit + sequence) — modelled loose because the
/// integrative protocol library is still in flight; the validation layer
/// (`lib/validation/infusion-log.ts`) constrains the shape.
///
/// Lifecycle: SCHEDULED -> IN_PROGRESS -> COMPLETED, or -> ABORTED from
/// any non-terminal state (see `InfusionStatus`). Transitions are gated
/// in `lib/services/infusion-log.ts`.
///
/// onDelete policy:
///   - Patient & Staff: `Restrict` — never silently lose an infusion
///     record when a person is removed (clinical traceability).
///   - Consultation: `SetNull` — keep the infusion intact if the
///     originating consultation is removed.
model InfusionLog {
  id             String  @id @default(uuid()) @db.Uuid
  patientId      String  @map("patient_id") @db.Uuid
  consultationId String? @map("consultation_id") @db.Uuid
  staffId        String  @map("staff_id") @db.Uuid

  /// Free-form protocol label, e.g. "Myers' Cocktail", "Glutathione Push".
  protocol String
  /// Per-agent order. Validated as
  /// `Array<{ name: string; dose: number; unit: string; sequence: number }>`
  /// at the route boundary; stored verbatim here.
  agents   Json

  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")

  /// Free-text reaction note — populated when the patient flags any
  /// adverse response (rash, dizziness, vasovagal, etc.). Null on a
  /// clean infusion.
  reaction String?

  status InfusionStatus @default(SCHEDULED)

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  consultation Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  staff        Staff         @relation("InfusionStaff", fields: [staffId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([staffId])
  @@index([status])
  @@map("infusion_logs")
}

// ===========================================================================
// Notifications (BE-45)
// ===========================================================================
//
// In-app notification feed for staff and patient logins. Domain events
// (RMO -> Doctor handoff, plan signed, invoice paid, ...) fan out by
// inserting one row per recipient via `lib/services/notifications.ts`
// `emitNotification`. The API surface is intentionally tiny:
//   - GET    /api/notifications           — list (paginated, unread filter)
//   - POST   /api/notifications/:id/read  — mark a single notification read
//   - POST   /api/notifications/read-all  — mark every notification read
//
// `sourceType` + `sourceRefId` is a polymorphic back-reference — no FK,
// the emitter fills in whatever entity is meaningful for the kind. The
// `(userId, kind, sourceType, sourceRefId)` tuple is the idempotency key
// when all four are present; emitters that re-fire the same event get a
// no-op.

enum NotificationKind {
  HANDOFF // RMO -> Doctor consultation handoff
  APPOINTMENT_REMINDER // generated by the BE-35 reminder scheduler in a later sprint
  INVOICE_ISSUED
  PAYMENT_RECEIVED
  PLAN_SIGNED
  GENERIC
}

model Notification {
  id     String @id @default(uuid()) @db.Uuid
  /// Recipient — User table (staff and patient logins both live there).
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind  NotificationKind
  title String
  body  String?

  /// Polymorphic backreference — caller fills in source type + id, no FK.
  sourceType  String? @map("source_type")
  sourceRefId String? @map("source_ref_id") @db.Uuid

  /// When set, the notification is considered read.
  readAt DateTime? @map("read_at") @db.Timestamptz()

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@index([sourceType, sourceRefId])
  @@map("notifications")
}

// ===========================================================================
// AssessmentSubmission — public-site Health Assessment quiz capture.
// ===========================================================================

/// Severity band from the scoring engine. Mirrored from the public-site
/// `SeverityBand` TypeScript type so the admin views can format submissions
/// consistently.
enum AssessmentBand {
  OPTIMAL
  MILD
  MODERATE
  SIGNIFICANT
}

/// Lifecycle of an assessment-driven booking. Reception confirms a slot
/// → CONFIRMED. Doctor sees the patient → COMPLETED. Patient cancels or
/// no-shows → CANCELLED.
enum AssessmentSubmissionStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

/// One row per completed Health Assessment quiz on the public site.
///
/// Each quiz submission is an immutable record — when a returning patient
/// retakes the quiz we INSERT a fresh row (we never update). That gives
/// the doctor a longitudinal view of how a patient's score moves over
/// time. The `patientId` links every row to the (auto-upserted) patient.
///
/// `answers`, `byCategory`, `topRisks`, and `suggestedFocus` are stored
/// as JSONB so the schema doesn't need to change every time the public
/// quiz adds a new question or category.
model AssessmentSubmission {
  id String @id @default(uuid()) @db.Uuid

  /// Patient this submission belongs to. We upsert by email when a brand-
  /// new visitor books an assessment so a Patient always exists by the
  /// time the row is written. Restrict on delete — we don't want to lose
  /// clinical-history artefacts when a patient row gets removed.
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  /// Snapshot of the contact details supplied at the time of booking.
  /// These can drift from the Patient row over time (the patient may
  /// later update their phone number, for example), and we want the
  /// booking record to preserve the values the patient actually gave us.
  contactName  String  @map("contact_name")
  contactEmail String  @map("contact_email") @db.Citext
  contactPhone String  @map("contact_phone")
  contactSex   String? @map("contact_sex")

  /// Requested booking slot. UTC timestamp combined from the date +
  /// time strings the booking form posts. We keep the raw time string
  /// alongside the timestamp so the admin UI can render the patient's
  /// preferred local time even if the server timezone differs.
  preferredAt   DateTime @map("preferred_at") @db.Timestamptz()
  preferredTime String   @map("preferred_time")
  notes         String?

  /// Scoring output.
  totalScore Int            @map("total_score")
  scoreOutOf Int            @map("score_out_of")
  band       AssessmentBand

  /// Per-category subtotals, top risks, and suggested focus as returned
  /// by `scoreQuiz()`. Kept as JSON so adding categories to the quiz
  /// doesn't require a migration.
  byCategory     Json @map("by_category")
  topRisks       Json @map("top_risks")
  suggestedFocus Json @map("suggested_focus")

  /// Raw answer payload — the exact map of question id → answer value
  /// the public site sent in. Enough to reconstruct the patient's full
  /// quiz on the admin detail page.
  answers Json

  /// Human-readable booking reference (e.g. "BOOK-A1B2C3D4"). The
  /// confirmation page shows this to the patient.
  bookingRef String @unique @map("booking_ref")

  status AssessmentSubmissionStatus @default(REQUESTED)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Admin list view orders by most recent first; the per-patient
  // history view orders by createdAt descending too.
  @@index([createdAt(sort: Desc)])
  @@index([patientId, createdAt(sort: Desc)])
  @@index([status])
  @@map("assessment_submissions")
}

// ===========================================================================
// App settings (key-value)
// ===========================================================================

/// Generic key-value settings store for admin-configurable app config (e.g.
/// the "email" key holds SMTP credentials for the transactional mailer).
/// Values are JSON; secrets inside them are encrypted at rest by the app
/// layer (see lib/crypto.ts) — never store plaintext credentials here.
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
