// Vyara — Prisma schema
//
// Initial scaffold. Models are introduced incrementally:
//   BE-03  : User, Role, Patient, Staff, Department, AuditLog (this commit)
//   BE-13  : Consultation (RMO + Main, sectioned JSONB)
//   BE-16  : LabResult (per-panel rows with analytes JSONB)
//   BE-24  : TreatmentPlan + plan items
//   BE-27  : Appointment
//   BE-37  : Invoice / InvoiceItem / Payment
//
// Run `npm run prisma:format` after edits to keep style consistent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Enums
// ===========================================================================

/// Clinic-side roles. A staff member always has exactly one role; a patient
/// has no Role (they sign in via a separate patient portal in BE-47).
enum Role {
  ADMIN
  DOCTOR
  RMO
  RECEPTION
  INFUSION_SPECIALIST
  REHAB_SPECIALIST
  AESTHETICS_SPECIALIST
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNDISCLOSED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
}

enum ConsultationType {
  RMO
  MAIN
}

enum ConsultationStatus {
  DRAFT
  RMO_DONE
  IN_PROGRESS
  SIGNED
}

/// Appointment lifecycle (BE-27).
///
///   REQUESTED  -> CONFIRMED | CANCELLED
///   CONFIRMED  -> COMPLETED | CANCELLED | NO_SHOW
///   COMPLETED / CANCELLED / NO_SHOW are terminal.
///
/// Only REQUESTED + CONFIRMED rows participate in slot-conflict checks —
/// once a slot is COMPLETED / CANCELLED / NO_SHOW it no longer holds the
/// staff member's time. Transitions are enforced in the service layer
/// (`lib/services/appointment.ts`).
enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ===========================================================================
// Auth & org
// ===========================================================================

/// A login account. Always 1:1 with Staff for clinic users.
/// Patient portal logins (BE-47) will use a separate model.
model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.Citext
  passwordHash String    @map("password_hash")
  role         Role
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  staff   Staff?
  /// 1:1 back-relation for unified-portal logins where role=PATIENT.
  patient Patient?

  consultationsCreated Consultation[] @relation("ConsultationCreator")
  consultationsSigned  Consultation[] @relation("ConsultationSigner")

  passwordResetOtps PasswordResetOtp[]

  @@index([role])
  @@map("users")
}

model Department {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  /// Default service pricing for this department (BE-31).
  ///
  /// JSONB map of `serviceCode -> priceCents` (integer paise/cents).
  /// Example: `{ "consultation": 50000, "follow_up": 30000 }`.
  /// Read by the appointment + invoice surfaces to seed line-item amounts
  /// when a more specific override isn't set. The shape is intentionally
  /// open-ended for Sprint 1 — BE-37 will introduce a normalised
  /// `ServicePrice` table and migrate values out of this column.
  defaultPricing Json?    @map("default_pricing")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  staff        Staff[]
  appointments Appointment[]

  @@map("departments")
}

model Staff {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @unique @map("user_id") @db.Uuid
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  fullName       String    @map("full_name")
  phone          String?
  dateOfBirth    DateTime? @map("date_of_birth") @db.Date
  specialization String?
  licenseNumber  String?   @map("license_number")
  experienceYrs  Int?      @map("experience_yrs")
  qualifications String[]  @default([])
  biography      String?
  avatarUrl      String?   @map("avatar_url")
  address        String?
  isActive       Boolean   @default(true) @map("is_active")
  joinedAt       DateTime? @map("joined_at") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Patients this staff member is the primary doctor for.
  primaryPatients Patient[] @relation("PrimaryDoctor")

  // Appointments where this staff member is the assigned doctor/RMO (BE-27).
  appointments        Appointment[] @relation("AppointmentStaff")
  // Appointments this staff member created (typically RECEPTION).
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")

  @@index([departmentId])
  @@map("staff")
}

// ===========================================================================
// Patients
// ===========================================================================

model Patient {
  id            String @id @default(uuid()) @db.Uuid
  /// Human-readable patient number, e.g. "PAT-263040".
  /// Generated via a sequence in BE-09 seed/migration.
  patientNumber String @unique @map("patient_number")

  fullName         String    @map("full_name")
  email            String?   @db.Citext
  phone            String?
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  sex              Sex?
  occupation       String?
  placeOfResidence String?   @map("place_of_residence")
  address          String?

  status PatientStatus @default(ACTIVE)

  /// Optional 1:1 back-relation to a unified-portal login. Populated for
  /// patients who have signed up for the patient portal (BE-47 + unified
  /// portal consolidation). Nullable because clinic-created patients won't
  /// have a User row until they self-enroll.
  userId String? @unique @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Optional primary doctor (Staff with role DOCTOR).
  primaryDoctorId String? @map("primary_doctor_id") @db.Uuid
  primaryDoctor   Staff?  @relation("PrimaryDoctor", fields: [primaryDoctorId], references: [id], onDelete: SetNull)

  referralSource String? @map("referral_source")

  /// Soft delete — set when status becomes ARCHIVED. Keep the row for audit.
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consultations Consultation[]
  appointments  Appointment[]

  @@index([status])
  @@index([primaryDoctorId])
  @@index([fullName])
  @@map("patients")
}

// ===========================================================================
// Consultations (BE-13)
// ===========================================================================

/// A clinical encounter. Polymorphic single-table design — `type` discriminates
/// between an RMO intake pass and the senior doctor's main consultation, and
/// the per-section payload lives in the `sections` JSONB blob. We deliberately
/// chose JSONB over normalized per-section tables because the intake form has
/// ~150 fields across 30+ sub-sections; per-section tables would explode the
/// migration surface area with no query benefit at clinic scale.
model Consultation {
  id        String  @id @default(uuid()) @db.Uuid
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  type   ConsultationType
  status ConsultationStatus @default(DRAFT)

  /// The RMO or Doctor who started this consultation.
  createdById String? @map("created_by_id") @db.Uuid
  createdBy   User?   @relation("ConsultationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  /// Set when the consultation transitions to SIGNED. After signing the row
  /// is immutable (enforced in BE-14's service layer).
  signedById String?   @map("signed_by_id") @db.Uuid
  signedBy   User?     @relation("ConsultationSigner", fields: [signedById], references: [id], onDelete: SetNull)
  signedAt   DateTime? @map("signed_at")

  /// Free-form sectioned content. For RMO: keys "informant", "demographics",
  /// "medicalHistory", "socialHistory", "personalHistory", "examinationSummary".
  /// For MAIN: "chiefComplaint", "hpi", "assessment", "diagnosis", "plan".
  sections Json @default("{}")

  /// Optional summary surfaced in the patient timeline.
  summary String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([patientId, type, createdAt])
  @@index([status])
  @@index([createdById])
  @@map("consultations")
}

// ===========================================================================
// Audit log
// ===========================================================================

/// Append-only audit trail. Every read/write of PHI writes a row here.
/// Surfaced through an admin viewer endpoint in BE-23.
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  occurredAt DateTime @default(now()) @map("occurred_at")

  /// Who did it (null for system events).
  actorUserId String? @map("actor_user_id") @db.Uuid

  action     AuditAction
  /// Entity table/model name, e.g. "Patient", "Consultation".
  entityType String      @map("entity_type")
  /// Primary key of the affected row (string so it fits uuid + bigint).
  entityId   String?     @map("entity_id")

  /// Optional structured detail (request ip, before/after diff, etc.).
  detail Json?

  @@index([entityType, entityId])
  @@index([actorUserId, occurredAt])
  @@index([occurredAt])
  @@map("audit_logs")
}

// ===========================================================================
// Appointments (BE-27)
// ===========================================================================

/// A scheduled clinical encounter between a Patient and a Staff member
/// (typically a doctor or RMO). The lifecycle is `AppointmentStatus` —
/// transitions are gated in `lib/services/appointment.ts`.
///
/// Slot-conflict semantics:
/// On create / time-edit, the service rejects any overlap on `staffId`
/// with another appointment whose status is in `{REQUESTED, CONFIRMED}`.
/// COMPLETED / CANCELLED / NO_SHOW rows no longer hold the slot.
///
/// onDelete policy:
///   - Patient & Staff: `Restrict` — never silently lose a scheduled
///     appointment when a person is removed.
///   - Department: `SetNull` — departments can be retired without
///     dropping historical bookings.
model Appointment {
  id String @id @default(uuid()) @db.Uuid

  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  /// Assigned doctor / RMO for this appointment.
  staffId String @map("staff_id") @db.Uuid
  staff   Staff  @relation("AppointmentStaff", fields: [staffId], references: [id], onDelete: Restrict)

  /// Optional department snapshot — useful for room/queue routing in
  /// later sprints. SetNull keeps history intact if the department is
  /// retired.
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  startsAt DateTime @map("starts_at") @db.Timestamptz()
  endsAt   DateTime @map("ends_at") @db.Timestamptz()

  status AppointmentStatus @default(REQUESTED)

  /// Short free-text reason for the visit (chief complaint shorthand).
  reason String?
  /// Optional reception/clinical notes attached to the booking itself
  /// (not the consultation — that's a separate row).
  notes  String?

  /// Who booked the appointment. Optional — system-created bookings
  /// (e.g. follow-up suggestions in BE-28) may have no creator.
  createdById String? @map("created_by_id") @db.Uuid
  createdBy   Staff?  @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  /// Stamped when the row transitions to CANCELLED. Kept for audit /
  /// patient-timeline display alongside `cancelledReason`.
  cancelledAt     DateTime? @map("cancelled_at") @db.Timestamptz()
  cancelledReason String?   @map("cancelled_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Slot-conflict checks scan by (staffId, startsAt).
  @@index([staffId, startsAt])
  // Patient timeline view orders most-recent first.
  @@index([patientId, startsAt(sort: Desc)])
  @@map("appointments")
}

// ===========================================================================
// NextAuth (BE-04)
// ===========================================================================
//
// We use the JWT session strategy, so these models are not exercised at
// runtime. They are declared because the PrismaAdapter contract expects
// them to exist when present, and we want zero-friction migration to the
// database-session strategy later.
//
// The `passwordHash` column on User already exists from BE-03 and is the
// canonical credential store; the `Account` model (used by OAuth providers)
// is intentionally omitted until we add a non-credentials provider.

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================================================================
// Password reset (BE-05)
// ===========================================================================

/// One row per OTP request. The plaintext OTP is never stored — only its
/// bcrypt hash. The row is burned (usedAt set) on successful verification.
///
/// Rate-limit policy lives in the route layer: max 5 requests per email per
/// rolling hour, counted via `createdAt`. A Sprint-2 hardening item is to
/// move this to Redis or a token bucket (`docs/auth.md`).
model PasswordResetOtp {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// bcrypt hash of the 6-digit code.
  otpHash String @map("otp_hash")

  /// Absolute expiry — set to createdAt + ~15 min at issue time.
  expiresAt DateTime @map("expires_at")

  /// Set on successful verification. Once non-null the row is consumed and
  /// cannot satisfy another verify call.
  usedAt DateTime? @map("used_at")

  /// Number of verify attempts against this OTP. Caller bumps on each
  /// mismatch and stops accepting the row at 5 attempts.
  attempts Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("password_reset_otps")
}
